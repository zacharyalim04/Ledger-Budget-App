# Copy this file to ".env" and fill in your Supabase project values to enable
# cloud sync + logins. Leave the file absent (or values blank) to run in LOCAL
# mode, which needs no account and saves to the browser.
#
# Find these in your Supabase dashboard: Project Settings > API.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
